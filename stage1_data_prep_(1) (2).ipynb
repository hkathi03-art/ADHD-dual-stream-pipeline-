def save_array(arr: np.ndarray, name: str, path: Path) -> dict:
    """
    Save numpy array and return metadata row.
    """
    fpath = path / f"{name}.npy"
    np.save(fpath, arr)
    mb = fpath.stat().st_size / 1e6
    print(f"  {name:35s}  {str(arr.shape):22s}  {mb:7.1f} MB")
    return {
        "artifact_name": name,
        "file_name": f"{name}.npy",
        "shape": list(arr.shape),
        "size_mb": round(mb, 3),
        "path": str(fpath),
    }


