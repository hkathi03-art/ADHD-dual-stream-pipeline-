        print(f"  {fname:42s}  {f.stat().st_size/1e6:7.3f} MB")

print()
print("Fold outputs:")
for fname in ["fold_assignments.json", "fold_assignments_table.csv"]:
    f = FOLD_DIR / fname
    if f.exists():
        print(f"  {fname:42s}  {f.stat().st_size/1e6:7.3f} MB")

print()
