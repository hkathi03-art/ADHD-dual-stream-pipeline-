def compute_metrics_binary(y_true, prob_pos, threshold=0.5):
    """
    Standardized binary classification metrics.
    """
    y_true = np.asarray(y_true).astype(int)
    prob_pos = np.asarray(prob_pos).astype(float)
    pred = (prob_pos >= threshold).astype(int)

    out = {
        "auc": float(roc_auc_score(y_true, prob_pos)),
        "pr_auc": float(average_precision_score(y_true, prob_pos)),
        "f1": float(f1_score(y_true, pred, zero_division=0)),
        "acc": float(accuracy_score(y_true, pred)),
        "balanced_acc": float(balanced_accuracy_score(y_true, pred)),
        "precision": float(precision_score(y_true, pred, zero_division=0)),
        "recall": float(recall_score(y_true, pred, zero_division=0)),
    }

    tn, fp, fn, tp = confusion_matrix(y_true, pred, labels=[0, 1]).ravel()
    out["tn"] = int(tn)
    out["fp"] = int(fp)
    out["fn"] = int(fn)
    out["tp"] = int(tp)
    out["n"] = int(len(y_true))
    out["positive_rate"] = float(y_true.mean())
    return out


def make_class_weights(y_train):
    """
    Balanced class weights for CrossEntropyLoss.
    """
    y_train = np.asarray(y_train).astype(int)
    n_pos = max(int((y_train == 1).sum()), 1)
    n_neg = max(int((y_train == 0).sum()), 1)
    total = n_pos + n_neg
    w0 = total / (2 * n_neg)
    w1 = total / (2 * n_pos)
    return torch.tensor([w0, w1], dtype=torch.float32, device=device)


def save_json(obj, path):
    with open(path, "w") as f:
        json.dump(obj, f, indent=2)


def save_predictions_csv(subject_ids, y_true, prob_pos, model_name, fold_idx, out_path):
    prob_pos = np.asarray(prob_pos).astype(float)
    pred = (prob_pos >= 0.5).astype(int)

    df = pd.DataFrame({
        "subject_id": np.asarray(subject_ids).astype(str),
        "true_label": np.asarray(y_true).astype(int),
        "pred_label": pred.astype(int),
        "pred_prob": prob_pos,
        "fold": int(fold_idx),
        "model_name": model_name,
    })
    df.to_csv(out_path, index=False)
    return df


# ============================================================
# Resistance-distance construction
# ============================================================
def build_laplacian(W: np.ndarray) -> np.ndarray:
    """
    Combinatorial graph Laplacian L = D - W
    """
    D = np.diag(W.sum(axis=1))
    return D - W


def resistance_distance_matrix(W: np.ndarray, rcond: float = 1e-6) -> np.ndarray:
    """
    Compute full resistance distance matrix using Laplacian pseudoinverse.
    Omega[i,j] = L+[i,i] + L+[j,j] - 2*L+[i,j]
    """
    L = build_laplacian(W)
    Lp = np.linalg.pinv(L, rcond=rcond)

    diag = np.diag(Lp)
    Omega = diag[:, None] + diag[None, :] - 2 * Lp

    Omega = np.clip(Omega, 0, None)
    np.fill_diagonal(Omega, 0.0)
    return Omega.astype(np.float32)


def compute_resistance_matrices(FC_mag: np.ndarray, rcond: float = 1e-6) -> np.ndarray:
    """
    Compute resistance distance matrices for the full cohort.
    """
    n_subjects = len(FC_mag)
    Omega_all = np.zeros_like(FC_mag, dtype=np.float32)

    for i in tqdm(range(n_subjects), desc="Computing resistance matrices"):
        Omega_all[i] = resistance_distance_matrix(FC_mag[i], rcond=rcond)

    return Omega_all


