    tr_ids = np.array(fold["train_ids"], dtype=str)
    val_ids = np.array(fold["val_ids"], dtype=str)

    id_to_idx = {sid: i for i, sid in enumerate(train_subject_ids)}
    tr_idx = np.array([id_to_idx[sid] for sid in tr_ids], dtype=int)
    val_idx = np.array([id_to_idx[sid] for sid in val_ids], dtype=int)

    # Spectral branch
    sc_spec = StandardScaler()
    pca_spec = PCA(n_components=PCA_SPEC_DIM, random_state=SEED)

    spec_tr = pca_spec.fit_transform(sc_spec.fit_transform(spec_train[tr_idx]))
    spec_val = pca_spec.transform(sc_spec.transform(spec_train[val_idx]))
    spec_test_fold = pca_spec.transform(sc_spec.transform(spec_test))

    # CNN embedding branch
    sc_cnn = StandardScaler()
    pca_cnn = PCA(n_components=PCA_CNN_DIM, random_state=SEED)

    cnn_tr = pca_cnn.fit_transform(sc_cnn.fit_transform(cnn_embeddings_all[tr_idx]))
    cnn_val = pca_cnn.transform(sc_cnn.transform(cnn_embeddings_all[val_idx]))
    cnn_test_fold = pca_cnn.transform(sc_cnn.transform(cnn_test_embeddings))

    # Concatenate
    X_tr = np.hstack([spec_tr, cnn_tr]).astype(np.float32)
    X_val = np.hstack([spec_val, cnn_val]).astype(np.float32)
    X_test_fold = np.hstack([spec_test_fold, cnn_test_fold]).astype(np.float32)

    fused_features_all[val_idx] = X_val
    test_fused_sum += X_test_fold
    test_fused_count += 1

    svm = SVC(kernel="rbf", probability=True, random_state=SEED, C=1.0, class_weight="balanced")
    svm.fit(X_tr, y[tr_idx])

    val_probs = svm.predict_proba(X_val)[:, 1]
    val_metrics = compute_metrics_binary(y[val_idx], val_probs)

    pred_path = OUT_DIR / f"svm_resistance_fold_{fold_idx}_predictions.csv"
    save_predictions_csv(
        subject_ids=val_ids,
        y_true=y[val_idx],
        prob_pos=val_probs,
        model_name="Resistance-SVM",
        fold_idx=fold_idx,
        out_path=pred_path
    )

    fold_result = {
        "fold": int(fold_idx),
        "train_n": int(len(tr_idx)),
        "val_n": int(len(val_idx)),
        **val_metrics,
        "prediction_file": pred_path.name,
    }
    svm_results.append(fold_result)

    print(
        f"[SVM] Fold {fold_idx} | "
        f"AUC={val_metrics['auc']:.4f} | "
        f"F1={val_metrics['f1']:.4f} | "
        f"ACC={val_metrics['acc']:.4f} | "
        f"BAL_ACC={val_metrics['balanced_acc']:.4f}"
    )

fused_features_test_all = test_fused_sum / max(test_fused_count, 1)

# Save fused features
np.save(OUT_DIR / "resistance_fused_features_train.npy", fused_features_all)
np.save(OUT_DIR / "resistance_fused_features_test.npy", fused_features_test_all)

pd.DataFrame({
    "subject_id": train_subject_ids,
    **{f"res_fused_{i}": fused_features_all[:, i] for i in range(fused_features_all.shape[1])}
}).to_csv(OUT_DIR / "resistance_fused_features_train_with_ids.csv", index=False)

pd.DataFrame({
    "subject_id": test_subject_ids,
    **{f"res_fused_{i}": fused_features_test_all[:, i] for i in range(fused_features_test_all.shape[1])}
}).to_csv(OUT_DIR / "resistance_fused_features_test_with_ids.csv", index=False)

save_json({"fold_results": svm_results}, OUT_DIR / "svm_resistance_results.json")

