# ============================================================
# CNN on resistance matrices
# Important fix:
# NO per-subject min-max normalization.
# We use fold-fitted z-score normalization using train-fold stats only.
# ============================================================
class ResistanceCNN(nn.Module):
    """
    Lightweight CNN for learning deep features from resistance distance matrices.
    Input  : (batch, 1, 200, 200)
    Output : logits or embedding
    """
    def __init__(self, embed_dim: int = 128, n_classes: int = 2):
        super().__init__()

        self.encoder = nn.Sequential(
            nn.Conv2d(1, 16, kernel_size=3, padding=1),
            nn.BatchNorm2d(16),
            nn.ReLU(inplace=True),
            nn.MaxPool2d(2),

            nn.Conv2d(16, 32, kernel_size=3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(inplace=True),
            nn.MaxPool2d(2),

            nn.Conv2d(32, 64, kernel_size=3, padding=1),
            nn.BatchNorm2d(64),
            nn.ReLU(inplace=True),
            nn.MaxPool2d(2),
        )

        self.gap = nn.AdaptiveAvgPool2d(1)

        self.embed_head = nn.Sequential(
            nn.Flatten(),
            nn.Linear(64, embed_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(0.3),
        )

        self.classifier = nn.Linear(embed_dim, n_classes)

    def forward(self, x, return_embedding: bool = False):
        x = self.encoder(x)
        x = self.gap(x)
        emb = self.embed_head(x)
        if return_embedding:
            return emb
        return self.classifier(emb)


def fit_fold_matrix_normalizer(X_train):
    """
    Fit fold-level normalization on training matrices only.
    """
    mu = float(X_train.mean())
    sigma = float(X_train.std())
    if sigma < 1e-8:
        sigma = 1.0
    return {"mean": mu, "std": sigma}


def apply_fold_matrix_normalizer(X, norm_stats):
    """
    Apply training-fold normalization.
    """
    Xn = (X - norm_stats["mean"]) / norm_stats["std"]
    return Xn.astype(np.float32)


def evaluate_cnn_model(model, dataloader):
    """
    Fresh inference pass for metrics + embeddings.
    """
    model.eval()
    all_probs = []
    all_true = []
    all_embs = []

    with torch.no_grad():
        for X_b, y_b in dataloader:
            X_b = X_b.to(device)
            logits = model(X_b)
            probs = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()

            emb = model(X_b, return_embedding=True).cpu().numpy()
            all_probs.append(probs)
            all_true.append(y_b.numpy())
            all_embs.append(emb)

    prob_pos = np.concatenate(all_probs)
    y_true   = np.concatenate(all_true)
    embs     = np.vstack(all_embs)
    metrics  = compute_metrics_binary(y_true, prob_pos)
    return metrics, prob_pos, embs


# ------------------------------------------------------------
# CNN training config
# ------------------------------------------------------------
EMBED_DIM  = 128
BATCH_SIZE = 16
LR         = 1e-4
EPOCHS     = 50
PATIENCE   = 10

cnn_results = []
cnn_embeddings_all = np.zeros((N_TRAIN, EMBED_DIM), dtype=np.float32)
cnn_test_embeddings = np.zeros((N_TEST, EMBED_DIM), dtype=np.float32)

# To average test embeddings across folds
test_emb_sum = np.zeros((N_TEST, EMBED_DIM), dtype=np.float32)
test_emb_count = 0

for fold_idx in range(N_FOLDS):
    fold = fold_registry["folds"][fold_idx]

    tr_ids = np.array(fold["train_ids"], dtype=str)
    val_ids = np.array(fold["val_ids"], dtype=str)

    # ID-based mapping (not blind positional trust)
    id_to_idx = {sid: i for i, sid in enumerate(train_subject_ids)}
    tr_idx = np.array([id_to_idx[sid] for sid in tr_ids], dtype=int)
    val_idx = np.array([id_to_idx[sid] for sid in val_ids], dtype=int)

    X_train_fold = Omega_train[tr_idx]
    X_val_fold   = Omega_train[val_idx]
    y_train_fold = y[tr_idx]
    y_val_fold   = y[val_idx]

    # Fold-fitted normalization
    norm_stats = fit_fold_matrix_normalizer(X_train_fold)
    X_train_norm = apply_fold_matrix_normalizer(X_train_fold, norm_stats)
    X_val_norm   = apply_fold_matrix_normalizer(X_val_fold, norm_stats)
    X_test_norm  = apply_fold_matrix_normalizer(Omega_test, norm_stats)

    train_ds = TensorDataset(
        torch.tensor(X_train_norm[:, None, :, :], dtype=torch.float32),
        torch.tensor(y_train_fold, dtype=torch.long)
    )
    val_ds = TensorDataset(
        torch.tensor(X_val_norm[:, None, :, :], dtype=torch.float32),
        torch.tensor(y_val_fold, dtype=torch.long)
    )
    test_ds = TensorDataset(
        torch.tensor(X_test_norm[:, None, :, :], dtype=torch.float32),
        torch.zeros(len(X_test_norm), dtype=torch.long)  # dummy labels
    )

    train_dl = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True)
    val_dl   = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False)
    test_dl  = DataLoader(test_ds, batch_size=BATCH_SIZE, shuffle=False)

    model = ResistanceCNN(embed_dim=EMBED_DIM).to(device)
    optimizer = optim.Adam(model.parameters(), lr=LR, weight_decay=1e-4)
    class_weights = make_class_weights(y_train_fold)
    criterion = nn.CrossEntropyLoss(weight=class_weights)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode="max", patience=4, factor=0.5)

    best_auc = -np.inf
    best_state = None
    epochs_no_improve = 0
    history = []

    for epoch in range(EPOCHS):
        model.train()
        train_loss_sum = 0.0
        n_train_seen = 0

        for X_b, y_b in train_dl:
            X_b = X_b.to(device)
            y_b = y_b.to(device)

            optimizer.zero_grad()
            logits = model(X_b)
            loss = criterion(logits, y_b)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)
            optimizer.step()

            bs = X_b.size(0)
            train_loss_sum += loss.item() * bs
            n_train_seen += bs

        # Fresh validation pass every epoch
        val_metrics, _, _ = evaluate_cnn_model(model, val_dl)
        mean_train_loss = train_loss_sum / max(n_train_seen, 1)
        scheduler.step(val_metrics["auc"])

        history.append({
            "epoch": int(epoch + 1),
            "train_loss": float(mean_train_loss),
            "val_auc": float(val_metrics["auc"]),
            "val_f1": float(val_metrics["f1"]),
            "val_acc": float(val_metrics["acc"]),
            "val_balanced_acc": float(val_metrics["balanced_acc"]),
        })

        if val_metrics["auc"] > best_auc:
            best_auc = val_metrics["auc"]
            best_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}
            epochs_no_improve = 0
        else:
            epochs_no_improve += 1

        if epochs_no_improve >= PATIENCE:
            break

    # IMPORTANT FIX:
    # Reload best checkpoint, then do a fresh inference pass for final metrics.
    model.load_state_dict(best_state)

    final_val_metrics, final_val_probs, final_val_embs = evaluate_cnn_model(model, val_dl)

    # Save val embeddings in canonical training array positions
    cnn_embeddings_all[val_idx] = final_val_embs

    # Save test embeddings using best checkpoint
    model.eval()
    test_embs = []
    with torch.no_grad():
        for X_b, _ in test_dl:
            X_b = X_b.to(device)
            emb = model(X_b, return_embedding=True).cpu().numpy()
            test_embs.append(emb)
    test_embs = np.vstack(test_embs)
    test_emb_sum += test_embs
    test_emb_count += 1

    # Save model checkpoint
    ckpt_path = OUT_DIR / f"cnn_fold_{fold_idx}.pt"
    torch.save(best_state, ckpt_path)

    # Save fold predictions
    pred_path = OUT_DIR / f"cnn_fold_{fold_idx}_predictions.csv"
    save_predictions_csv(
        subject_ids=val_ids,
        y_true=y_val_fold,
        prob_pos=final_val_probs,
        model_name="Resistance-CNN",
        fold_idx=fold_idx,
        out_path=pred_path
    )

    # Save fold training history
    pd.DataFrame(history).to_csv(OUT_DIR / f"cnn_fold_{fold_idx}_training_history.csv", index=False)

    # Save fold normalization stats
    save_json(norm_stats, OUT_DIR / f"cnn_fold_{fold_idx}_normalization.json")

    fold_result = {
        "fold": int(fold_idx),
        "train_n": int(len(tr_idx)),
        "val_n": int(len(val_idx)),
        **final_val_metrics,
        "checkpoint_file": ckpt_path.name,
        "prediction_file": pred_path.name,
    }
    cnn_results.append(fold_result)

    print(
        f"[CNN] Fold {fold_idx} | "
        f"AUC={final_val_metrics['auc']:.4f} | "
        f"F1={final_val_metrics['f1']:.4f} | "
        f"ACC={final_val_metrics['acc']:.4f} | "
        f"BAL_ACC={final_val_metrics['balanced_acc']:.4f}"
    )

# Final averaged test embeddings across folds
cnn_test_embeddings = test_emb_sum / max(test_emb_count, 1)

# Save embeddings
np.save(OUT_DIR / "cnn_embeddings_train.npy", cnn_embeddings_all)
np.save(OUT_DIR / "cnn_embeddings_test.npy", cnn_test_embeddings)

pd.DataFrame({
    "subject_id": train_subject_ids,
    **{f"cnn_emb_{i}": cnn_embeddings_all[:, i] for i in range(cnn_embeddings_all.shape[1])}
}).to_csv(OUT_DIR / "cnn_embeddings_train_with_ids.csv", index=False)

pd.DataFrame({
    "subject_id": test_subject_ids,
    **{f"cnn_emb_{i}": cnn_test_embeddings[:, i] for i in range(cnn_test_embeddings.shape[1])}
}).to_csv(OUT_DIR / "cnn_embeddings_test_with_ids.csv", index=False)

save_json({"fold_results": cnn_results}, OUT_DIR / "cnn_cv_results.json")

