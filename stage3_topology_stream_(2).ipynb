# ============================================================
# GNN training
# Corrected:
# - ID-based fold selection
# - best-checkpoint re-evaluation
# - per-fold predictions
# - embeddings saved with subject_id
# ============================================================
IN_DIM = train_X_nodes.shape[-1]
HIDDEN_DIM = 128
EMBED_DIM = 128
BATCH_SIZE = 16
LR = 1e-3
WEIGHT_DECAY = 1e-4
EPOCHS = 60
PATIENCE = 10

gnn_results = []
gnn_embeddings_train = np.zeros((N_TRAIN, EMBED_DIM), dtype=np.float32)
test_emb_sum = np.zeros((N_TEST, EMBED_DIM), dtype=np.float32)
test_emb_count = 0

def evaluate_gnn_model(model, X_nodes, A_norm, y_true, batch_size=16):
    model.eval()
    all_probs = []
    all_embs = []

    with torch.no_grad():
        for start in range(0, len(X_nodes), batch_size):
            end = start + batch_size
            xb = torch.tensor(X_nodes[start:end], dtype=torch.float32, device=device)
            ab = torch.tensor(A_norm[start:end], dtype=torch.float32, device=device)

            logits = model(xb, ab)
            probs = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()

            emb = model(xb, ab, return_embedding=True).cpu().numpy()
            all_probs.append(probs)
            all_embs.append(emb)

    prob_pos = np.concatenate(all_probs)
    embs = np.vstack(all_embs)
    metrics = compute_metrics_binary(y_true, prob_pos)
    return metrics, prob_pos, embs


for fold_idx in range(N_FOLDS):
    fold = fold_registry["folds"][fold_idx]
    tr_ids = np.array(fold["train_ids"], dtype=str)
    val_ids = np.array(fold["val_ids"], dtype=str)

    id_to_idx = {sid: i for i, sid in enumerate(train_subject_ids)}
    tr_idx = np.array([id_to_idx[sid] for sid in tr_ids], dtype=int)
    val_idx = np.array([id_to_idx[sid] for sid in val_ids], dtype=int)

    X_tr = train_X_nodes[tr_idx]
    A_tr = train_A_norm[tr_idx]
    y_tr = y[tr_idx]

    X_val = train_X_nodes[val_idx]
    A_val = train_A_norm[val_idx]
    y_val = y[val_idx]

    model = TopologyGNN(
        in_dim=IN_DIM,
        hidden_dim=HIDDEN_DIM,
        embed_dim=EMBED_DIM,
        dropout=0.25
    ).to(device)

    optimizer = optim.Adam(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
    class_weights = make_class_weights(y_tr)
    criterion = nn.CrossEntropyLoss(weight=class_weights)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode="max", patience=4, factor=0.5)

    best_auc = -np.inf
    best_state = None
    epochs_no_improve = 0
    history = []

    for epoch in range(EPOCHS):
        model.train()

        # Shuffle batch order
        perm = np.random.permutation(len(X_tr))
        train_loss_sum = 0.0
        n_seen = 0

        for start in range(0, len(perm), BATCH_SIZE):
            batch_idx = perm[start:start + BATCH_SIZE]

            xb = torch.tensor(X_tr[batch_idx], dtype=torch.float32, device=device)
            ab = torch.tensor(A_tr[batch_idx], dtype=torch.float32, device=device)
            yb = torch.tensor(y_tr[batch_idx], dtype=torch.long, device=device)

            optimizer.zero_grad()
            logits = model(xb, ab)
            loss = criterion(logits, yb)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)
            optimizer.step()

            bs = len(batch_idx)
            train_loss_sum += loss.item() * bs
            n_seen += bs

        val_metrics, _, _ = evaluate_gnn_model(model, X_val, A_val, y_val, batch_size=BATCH_SIZE)
        mean_train_loss = train_loss_sum / max(n_seen, 1)
        scheduler.step(val_metrics["auc"])

        history.append({
            "epoch": int(epoch + 1),
            "train_loss": float(mean_train_loss),
            "val_auc": float(val_metrics["auc"]),
            "val_f1": float(val_metrics["f1"]),
            "val_acc": float(val_metrics["acc"]),
            "val_balanced_acc": float(val_metrics["balanced_acc"]),
        })

        if val_metrics["auc"] > best_auc:
            best_auc = val_metrics["auc"]
            best_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}
            epochs_no_improve = 0
        else:
            epochs_no_improve += 1

        if epochs_no_improve >= PATIENCE:
            break

    # IMPORTANT FIX:
    # Reload best checkpoint, then perform fresh validation pass.
    model.load_state_dict(best_state)

    final_val_metrics, final_val_probs, final_val_embs = evaluate_gnn_model(
        model, X_val, A_val, y_val, batch_size=BATCH_SIZE
    )

    gnn_embeddings_train[val_idx] = final_val_embs

    # Test embeddings from best checkpoint
    model.eval()
    all_test_embs = []
    with torch.no_grad():
        for start in range(0, len(test_X_nodes), BATCH_SIZE):
            end = start + BATCH_SIZE
            xb = torch.tensor(test_X_nodes[start:end], dtype=torch.float32, device=device)
            ab = torch.tensor(test_A_norm[start:end], dtype=torch.float32, device=device)
            emb = model(xb, ab, return_embedding=True).cpu().numpy()
            all_test_embs.append(emb)
    test_embs = np.vstack(all_test_embs)
    test_emb_sum += test_embs
    test_emb_count += 1

    ckpt_path = OUT_DIR / f"gnn_fold_{fold_idx}.pt"
    torch.save(best_state, ckpt_path)

    pred_path = OUT_DIR / f"gnn_fold_{fold_idx}_predictions.csv"
    save_predictions_csv(
        subject_ids=val_ids,
        y_true=y_val,
        prob_pos=final_val_probs,
        model_name="Topology-GNN",
        fold_idx=fold_idx,
        out_path=pred_path
    )

    pd.DataFrame(history).to_csv(OUT_DIR / f"gnn_fold_{fold_idx}_training_history.csv", index=False)

    gnn_results.append({
        "fold": int(fold_idx),
        "train_n": int(len(tr_idx)),
        "val_n": int(len(val_idx)),
        **final_val_metrics,
        "checkpoint_file": ckpt_path.name,
        "prediction_file": pred_path.name,
    })

    print(
        f"[GNN] Fold {fold_idx} | "
        f"AUC={final_val_metrics['auc']:.4f} | "
        f"F1={final_val_metrics['f1']:.4f} | "
        f"ACC={final_val_metrics['acc']:.4f} | "
        f"BAL_ACC={final_val_metrics['balanced_acc']:.4f}"
    )

gnn_embeddings_test = test_emb_sum / max(test_emb_count, 1)

# Save embeddings
np.save(OUT_DIR / "gnn_embeddings_train.npy", gnn_embeddings_train)
np.save(OUT_DIR / "gnn_embeddings_test.npy", gnn_embeddings_test)

