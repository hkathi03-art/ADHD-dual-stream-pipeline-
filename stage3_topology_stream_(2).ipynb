# ============================================================
# Node feature construction
# Corrected:
# - Uses sign-row profile as node-local information
# - Adds graph-global PH vector broadcast to nodes
# This is kept explicit and documented.
# ============================================================
def build_node_features(fc_sign: np.ndarray, ph_vec: np.ndarray) -> np.ndarray:
    """
    Node features = [sign-row profile, broadcast PH feature vector]
    shape: (n_nodes, n_nodes + ph_dim)
    """
    sign_profile = fc_sign.astype(np.float32)
    ph_broadcast = np.repeat(ph_vec[None, :], repeats=fc_sign.shape[0], axis=0).astype(np.float32)
    x = np.concatenate([sign_profile, ph_broadcast], axis=1).astype(np.float32)
    return x


train_node_features = [build_node_features(FC_train_sign[i], PH_train[i]) for i in range(N_TRAIN)]
test_node_features  = [build_node_features(FC_test_sign[i],  PH_test[i])  for i in range(N_TEST)]

# ============================================================
# GNN-like model using dense adjacency
# Corrected: one official implementation only
# Avoids duplicated helper paths and keeps evaluation simple.
# ============================================================
class GraphBlock(nn.Module):
    """
    Dense message passing block using normalized adjacency.
    """
    def __init__(self, in_dim, out_dim, dropout=0.2):
        super().__init__()
        self.lin_self = nn.Linear(in_dim, out_dim)
        self.lin_neigh = nn.Linear(in_dim, out_dim)
        self.norm = nn.LayerNorm(out_dim)
        self.dropout = nn.Dropout(dropout)
        self.act = nn.ReLU(inplace=True)

    def forward(self, x, A_norm):
        # x: (B, N, F), A_norm: (B, N, N)
        neigh = torch.bmm(A_norm, x)
        out = self.lin_self(x) + self.lin_neigh(neigh)
        out = self.norm(out)
        out = self.act(out)
        out = self.dropout(out)
        return out


class TopologyGNN(nn.Module):
    """
    Dense graph network for subject-level classification.
    """
    def __init__(self, in_dim, hidden_dim=128, embed_dim=128, dropout=0.2):
        super().__init__()
        self.input_proj = nn.Sequential(
            nn.Linear(in_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(dropout),
        )

        self.block1 = GraphBlock(hidden_dim, hidden_dim, dropout=dropout)
        self.block2 = GraphBlock(hidden_dim, hidden_dim, dropout=dropout)
        self.block3 = GraphBlock(hidden_dim, hidden_dim, dropout=dropout)

        self.readout = nn.Sequential(
            nn.Linear(hidden_dim, embed_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(dropout),
        )
        self.classifier = nn.Linear(embed_dim, 2)

    def forward(self, x, A_norm, return_embedding=False):
        # x: (B, N, F), A_norm: (B, N, N)
        h = self.input_proj(x)
        h = self.block1(h, A_norm)
        h = self.block2(h, A_norm)
        h = self.block3(h, A_norm)

        # global mean pool
        g = h.mean(dim=1)
        emb = self.readout(g)

        if return_embedding:
            return emb
        logits = self.classifier(emb)
        return logits


def build_dense_adjacency_from_spec(graph_spec, n_nodes=200):
    """
    Build dense weighted adjacency matrix from graph spec.
    Uses edge_weight * edge_sign as signed edge weight.
    """
    A = np.zeros((n_nodes, n_nodes), dtype=np.float32)
    for (u, v), w, s in zip(graph_spec["edge_list"], graph_spec["edge_weight"], graph_spec["edge_sign"]):
        val = float(w * s)
        A[u, v] = val
        A[v, u] = val
    return A


def normalize_adjacency(A: np.ndarray):
    """
    Symmetric normalization: D^{-1/2} (A + I) D^{-1/2}
    Works with signed weighted adjacency by normalizing absolute degree.
    """
    A_hat = A.copy()
    n = A_hat.shape[0]
    A_hat = A_hat + np.eye(n, dtype=np.float32)

    deg = np.sum(np.abs(A_hat), axis=1)
    deg = np.clip(deg, 1e-8, None)
    inv_sqrt = 1.0 / np.sqrt(deg)
    D_inv = np.diag(inv_sqrt.astype(np.float32))
    A_norm = D_inv @ A_hat @ D_inv
    return A_norm.astype(np.float32)


train_A_norm = np.stack(
    [normalize_adjacency(build_dense_adjacency_from_spec(gs, n_nodes=N_NODES)) for gs in train_graph_specs],
    axis=0
)
test_A_norm = np.stack(
    [normalize_adjacency(build_dense_adjacency_from_spec(gs, n_nodes=N_NODES)) for gs in test_graph_specs],
    axis=0
)

train_X_nodes = np.stack(train_node_features, axis=0).astype(np.float32)
test_X_nodes  = np.stack(test_node_features, axis=0).astype(np.float32)

print(f"Node feature shape train : {train_X_nodes.shape}")  # (N, 200, 300)
print(f"Adjacency shape train    : {train_A_norm.shape}")   # (N, 200, 200)

