# ============================================================
# Graph construction
# Corrected: one official graph path only
# Graph built from magnitude FC to select edges.
# Sign FC provides edge sign attributes.
# ============================================================
TOP_K_EXTRA_EDGES = 600

def build_sparse_graph_from_fc(fc_mag: np.ndarray, fc_sign: np.ndarray, top_k_extra: int = 600):
    """
    Build one sparse graph:
    1) Maximum spanning tree on similarity weights (via MST on negative weights)
    2) Add top-k extra edges by magnitude
    3) Return adjacency, edge list, edge sign, and edge weight
    """
    n = fc_mag.shape[0]
    W = fc_mag.copy().astype(np.float32)
    S = fc_sign.copy().astype(np.float32)

    np.fill_diagonal(W, 0.0)
    np.fill_diagonal(S, 0.0)

    # Maximum spanning tree using minimum spanning tree on negative weights
    negW = -W
    mst_sparse = minimum_spanning_tree(negW)
    mst_edges = np.array(mst_sparse.nonzero()).T

    # Normalize order of undirected edges
    mst_edge_set = set()
    for u, v in mst_edges:
        a, b = sorted((int(u), int(v)))
        mst_edge_set.add((a, b))

    # Candidate edges sorted by descending weight
    iu, iv = np.triu_indices(n, k=1)
    weights = W[iu, iv]
    order = np.argsort(weights)[::-1]

    edge_set = set(mst_edge_set)
    added = 0
    for idx in order:
        u = int(iu[idx])
        v = int(iv[idx])
        if W[u, v] <= 0:
            break
        if (u, v) not in edge_set:
            edge_set.add((u, v))
            added += 1
            if added >= top_k_extra:
                break

    edge_list = sorted(list(edge_set))
    edge_weight = np.array([W[u, v] for (u, v) in edge_list], dtype=np.float32)
    edge_sign = np.array([S[u, v] for (u, v) in edge_list], dtype=np.float32)

    return {
        "edge_list": edge_list,
        "edge_weight": edge_weight,
        "edge_sign": edge_sign,
        "num_edges": len(edge_list),
    }


