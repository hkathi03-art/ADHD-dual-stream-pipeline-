def compute_metrics_binary(y_true, prob_pos, threshold=0.5):
    y_true = np.asarray(y_true).astype(int)
    prob_pos = np.asarray(prob_pos).astype(float)
    pred = (prob_pos >= threshold).astype(int)

    out = {
        "auc": float(roc_auc_score(y_true, prob_pos)),
        "pr_auc": float(average_precision_score(y_true, prob_pos)),
        "f1": float(f1_score(y_true, pred, zero_division=0)),
        "acc": float(accuracy_score(y_true, pred)),
        "balanced_acc": float(balanced_accuracy_score(y_true, pred)),
        "precision": float(precision_score(y_true, pred, zero_division=0)),
        "recall": float(recall_score(y_true, pred, zero_division=0)),
    }

    tn, fp, fn, tp = confusion_matrix(y_true, pred, labels=[0, 1]).ravel()
    out["tn"] = int(tn)
    out["fp"] = int(fp)
    out["fn"] = int(fn)
    out["tp"] = int(tp)
    out["n"] = int(len(y_true))
    out["positive_rate"] = float(y_true.mean())
    return out


def save_json(obj, path):
    with open(path, "w") as f:
        json.dump(obj, f, indent=2)


def save_predictions_csv(subject_ids, y_true, prob_pos, model_name, fold_idx, out_path):
    prob_pos = np.asarray(prob_pos).astype(float)
    pred = (prob_pos >= 0.5).astype(int)
    df = pd.DataFrame({
        "subject_id": np.asarray(subject_ids).astype(str),
        "true_label": np.asarray(y_true).astype(int),
        "pred_label": pred.astype(int),
        "pred_prob": prob_pos,
        "fold": int(fold_idx),
        "model_name": model_name,
    })
    df.to_csv(out_path, index=False)
    return df


def make_class_weights(y_train):
    y_train = np.asarray(y_train).astype(int)
    n_pos = max(int((y_train == 1).sum()), 1)
    n_neg = max(int((y_train == 0).sum()), 1)
    total = n_pos + n_neg
    w0 = total / (2 * n_neg)
    w1 = total / (2 * n_pos)
    return torch.tensor([w0, w1], dtype=torch.float32, device=device)


# ============================================================
# Persistent homology features
# Corrected: one official implementation only
# Uses magnitude FC as a similarity source converted to distance.
# ============================================================
PH_PER_DIM = 50   # 50 H0 + 50 H1 = 100 total features
PH_MAXDIM = 1

def similarity_to_distance(W: np.ndarray) -> np.ndarray:
    """
    Convert nonnegative similarity matrix to a distance matrix.
    Uses D = max(W) - W, with zero diagonal.
    """
    W = np.asarray(W, dtype=np.float32)
    W = W.copy()
    np.fill_diagonal(W, 0.0)
    max_w = float(W.max())
    D = max_w - W
    D = np.clip(D, 0, None)
    D = (D + D.T) / 2.0
    np.fill_diagonal(D, 0.0)
    return D.astype(np.float32)


def diagram_to_topk(diagram: np.ndarray, top_k: int = 50) -> np.ndarray:
    """
    Convert persistence diagram to top-k persistence lifetimes.
    Pads with zeros if needed.
    """
    if diagram is None or len(diagram) == 0:
        return np.zeros(top_k, dtype=np.float32)

    births = diagram[:, 0]
    deaths = diagram[:, 1]

    finite_mask = np.isfinite(deaths)
    if finite_mask.sum() == 0:
        return np.zeros(top_k, dtype=np.float32)

    persistence = deaths[finite_mask] - births[finite_mask]
    persistence = np.clip(persistence, 0, None)

    persistence = np.sort(persistence)[::-1]
    out = np.zeros(top_k, dtype=np.float32)
    k = min(top_k, len(persistence))
    out[:k] = persistence[:k]
    return out


def compute_ph_features(FC_mag: np.ndarray, top_k_per_dim: int = 50, maxdim: int = 1) -> np.ndarray:
    """
    Compute PH features from magnitude FC.
    Returns shape: (n_subjects, top_k_per_dim * (maxdim+1))
    """
    n_subjects = len(FC_mag)
    n_feats = top_k_per_dim * (maxdim + 1)
    feats = np.zeros((n_subjects, n_feats), dtype=np.float32)

    for i in tqdm(range(n_subjects), desc="Computing PH features"):
        D = similarity_to_distance(FC_mag[i])

        ph = ripser(D, distance_matrix=True, maxdim=maxdim)
        dgms = ph["dgms"]

        feat_parts = []
        for dim in range(maxdim + 1):
            feat_parts.append(diagram_to_topk(dgms[dim], top_k=top_k_per_dim))
        feats[i] = np.concatenate(feat_parts).astype(np.float32)

    return feats


