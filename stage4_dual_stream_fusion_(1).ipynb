    return fold, tr_ids, val_ids, tr_idx, val_idx


# ============================================================
# Model definitions
# ============================================================
class CrossModalGate(nn.Module):
    """
    Sample-wise cross-modal gating.
    This is a gated fusion block, not token-level attention.
    """
    def __init__(self, dim_q, dim_kv, hidden_dim=128):
        super().__init__()
        self.q_proj = nn.Linear(dim_q, hidden_dim)
        self.k_proj = nn.Linear(dim_kv, hidden_dim)
        self.v_proj = nn.Linear(dim_kv, hidden_dim)

    def forward(self, q, kv):
        qh = self.q_proj(q)
        kh = self.k_proj(kv)
        vh = self.v_proj(kv)

        score = torch.sum(qh * kh, dim=1, keepdim=True)
        alpha = torch.sigmoid(score)
        fused = alpha * vh
        return fused, alpha


class DualStreamFusionNet(nn.Module):
    """
    Dual-stream fusion network using:
    - resistance embedding as query
    - topology embedding as key/value
    plus optional auxiliary features
    """
    def __init__(self, res_dim, topo_dim, aux_dim=0, hidden_dim=128, fused_dim=128, dropout=0.3):
        super().__init__()

        self.res_branch = nn.Sequential(
            nn.Linear(res_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(dropout),
        )

        self.topo_branch = nn.Sequential(
            nn.Linear(topo_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(dropout),
        )

        self.gate = CrossModalGate(hidden_dim, hidden_dim, hidden_dim=hidden_dim)

        total_in = hidden_dim + hidden_dim + hidden_dim + aux_dim

        self.fusion_head = nn.Sequential(
            nn.Linear(total_in, fused_dim),
            nn.LayerNorm(fused_dim),
            nn.ReLU(inplace=True),
            nn.Dropout(dropout),
        )

        self.classifier = nn.Linear(fused_dim, 2)

    def forward(self, x_res, x_topo, x_aux=None, return_embedding=False, return_alpha=False):
        r = self.res_branch(x_res)
        t = self.topo_branch(x_topo)

        gated_topo, alpha = self.gate(r, t)

        if x_aux is not None:
            h = torch.cat([r, t, gated_topo, x_aux], dim=1)
        else:
            h = torch.cat([r, t, gated_topo], dim=1)

        fused = self.fusion_head(h)

        if return_embedding and return_alpha:
            return fused, alpha
        if return_embedding:
            return fused

        logits = self.classifier(fused)

        if return_alpha:
            return logits, alpha
        return logits


