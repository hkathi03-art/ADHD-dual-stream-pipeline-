# ============================================================
# Feature-block importance proxy
# Corrected labeling:
# this is NOT a true neural ablation, only a proxy using SVM on frozen fused blocks
# ============================================================
ablation_rows = []

feature_blocks_train = {
    "res_only": X_res_train,
    "topo_only": X_topo_train,
    "aux_only": np.hstack([X_ph_train, X_spec_train]).astype(np.float32),
    "res_plus_topo": np.hstack([X_res_train, X_topo_train]).astype(np.float32),
    "res_plus_aux": np.hstack([X_res_train, X_ph_train, X_spec_train]).astype(np.float32),
    "topo_plus_aux": np.hstack([X_topo_train, X_ph_train, X_spec_train]).astype(np.float32),
    "all_blocks": np.hstack([X_res_train, X_topo_train, X_ph_train, X_spec_train]).astype(np.float32),
}

for block_name, X_block in feature_blocks_train.items():
    fold_metrics_list = []

    for fold_idx in range(N_FOLDS):
        _, _, val_ids, tr_idx, val_idx = get_fold_indices(fold_idx)

        sc = StandardScaler()
        n_comp = min(64, X_block.shape[1], len(tr_idx) - 1)
        pca = PCA(n_components=max(2, n_comp), random_state=SEED)

        X_tr = pca.fit_transform(sc.fit_transform(X_block[tr_idx]))
        X_val = pca.transform(sc.transform(X_block[val_idx]))

        clf = SVC(kernel="rbf", probability=True, class_weight="balanced", random_state=SEED)
        clf.fit(X_tr, y_merged[tr_idx])
        val_probs = clf.predict_proba(X_val)[:, 1]

        fold_metrics_list.append(compute_metrics_binary(y_merged[val_idx], val_probs))

    summary = summarize_results([{**m} for m in fold_metrics_list])
    ablation_rows.append({
        "feature_block": block_name,
        "auc_mean": summary["auc"]["mean"],
        "auc_std": summary["auc"]["std"],
        "f1_mean": summary["f1"]["mean"],
        "acc_mean": summary["acc"]["mean"],
        "balanced_acc_mean": summary["balanced_acc"]["mean"],
    })

ablation_df = pd.DataFrame(ablation_rows).sort_values("auc_mean", ascending=False)
ablation_df.to_csv(OUT_DIR / "ablation_results.csv", index=False)

save_json({
    "note": (
        "This is a frozen-feature proxy ablation using classical SVM on feature blocks. "
        "It is not a direct ablation of the neural fusion architecture."
    ),
    "rows": ablation_rows
}, OUT_DIR / "ablation_results.json")

