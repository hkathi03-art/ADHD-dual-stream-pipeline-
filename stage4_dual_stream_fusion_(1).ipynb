    pca_top = PCA(n_components=TOPO_PCA_DIM, random_state=SEED)

    aux_train_full = np.hstack([X_ph_train, X_spec_train]).astype(np.float32)
    aux_test_full = np.hstack([X_ph_test, X_spec_test]).astype(np.float32)

    sc_aux = StandardScaler()
    pca_aux = PCA(n_components=AUX_PCA_DIM, random_state=SEED)

    Xr_tr = pca_res.fit_transform(sc_res.fit_transform(X_res_train[tr_idx]))
    Xr_val = pca_res.transform(sc_res.transform(X_res_train[val_idx]))
    Xr_test = pca_res.transform(sc_res.transform(X_res_test))

    Xt_tr = pca_top.fit_transform(sc_top.fit_transform(X_topo_train[tr_idx]))
    Xt_val = pca_top.transform(sc_top.transform(X_topo_train[val_idx]))
    Xt_test = pca_top.transform(sc_top.transform(X_topo_test))

    Xa_tr = pca_aux.fit_transform(sc_aux.fit_transform(aux_train_full[tr_idx]))
    Xa_val = pca_aux.transform(sc_aux.transform(aux_train_full[val_idx]))
    Xa_test = pca_aux.transform(sc_aux.transform(aux_test_full))

    y_tr = y_merged[tr_idx]
    y_val = y_merged[val_idx]

    train_ds = TensorDataset(
        torch.tensor(Xr_tr, dtype=torch.float32),
        torch.tensor(Xt_tr, dtype=torch.float32),
        torch.tensor(Xa_tr, dtype=torch.float32),
        torch.tensor(y_tr, dtype=torch.long),
    )

    val_ds = TensorDataset(
        torch.tensor(Xr_val, dtype=torch.float32),
        torch.tensor(Xt_val, dtype=torch.float32),
        torch.tensor(Xa_val, dtype=torch.float32),
        torch.tensor(y_val, dtype=torch.long),
    )

    train_dl = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True)
    val_dl = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False)

    model = DualStreamFusionNet(
        res_dim=RES_PCA_DIM,
        topo_dim=TOPO_PCA_DIM,
        aux_dim=AUX_PCA_DIM,
        hidden_dim=FUSION_HIDDEN,
        fused_dim=FUSION_EMBED,
        dropout=0.3
    ).to(device)

    optimizer = optim.Adam(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
    class_weights = make_class_weights(y_tr)
    criterion = nn.CrossEntropyLoss(weight=class_weights)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode="max", patience=4, factor=0.5)

    best_auc = -np.inf
    best_state = None
    epochs_no_improve = 0
    history = []

    for epoch in range(EPOCHS):
        model.train()
        loss_sum = 0.0
        n_seen = 0

        for xr, xt, xa, yb in train_dl:
            xr = xr.to(device)
            xt = xt.to(device)
            xa = xa.to(device)
            yb = yb.to(device)

            optimizer.zero_grad()
            logits = model(xr, xt, xa)
            loss = criterion(logits, yb)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)
            optimizer.step()

            bs = yb.size(0)
            loss_sum += loss.item() * bs
            n_seen += bs

        # Fresh validation pass each epoch
        val_metrics, _, _, _ = evaluate_fusion_model(model, Xr_val, Xt_val, Xa_val, y_val, batch_size=BATCH_SIZE)
        mean_loss = loss_sum / max(n_seen, 1)
        scheduler.step(val_metrics["auc"])

        history.append({
            "epoch": int(epoch + 1),
            "train_loss": float(mean_loss),
            "val_auc": float(val_metrics["auc"]),
            "val_f1": float(val_metrics["f1"]),
            "val_acc": float(val_metrics["acc"]),
            "val_balanced_acc": float(val_metrics["balanced_acc"]),
        })

        if val_metrics["auc"] > best_auc:
            best_auc = val_metrics["auc"]
            best_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}
            epochs_no_improve = 0
        else:
            epochs_no_improve += 1

        if epochs_no_improve >= PATIENCE:
            break

    # IMPORTANT FIX:
    # Reload best checkpoint and recompute final validation metrics from scratch
    model.load_state_dict(best_state)

    final_val_metrics, final_val_probs, final_val_embs, final_val_alpha = evaluate_fusion_model(
        model, Xr_val, Xt_val, Xa_val, y_val, batch_size=BATCH_SIZE
    )

    fusion_embeddings_train[val_idx] = final_val_embs
    attention_alpha_train[val_idx] = final_val_alpha

    # Test embeddings and alpha from best checkpoint
    model.eval()
    all_test_embs = []
    all_test_alpha = []
    with torch.no_grad():
        for start in range(0, len(Xr_test), BATCH_SIZE):
            end = start + BATCH_SIZE
            xr = torch.tensor(Xr_test[start:end], dtype=torch.float32, device=device)
            xt = torch.tensor(Xt_test[start:end], dtype=torch.float32, device=device)
            xa = torch.tensor(Xa_test[start:end], dtype=torch.float32, device=device)

            emb, alpha = model(xr, xt, xa, return_embedding=True, return_alpha=True)
            all_test_embs.append(emb.cpu().numpy())
            all_test_alpha.append(alpha.cpu().numpy())

    test_embs = np.vstack(all_test_embs)
    test_alpha = np.vstack(all_test_alpha)

    test_emb_sum += test_embs
    test_alpha_sum += test_alpha
    test_count += 1

    ckpt_path = OUT_DIR / f"fusion_fold_{fold_idx}.pt"
    torch.save(best_state, ckpt_path)

    pred_path = OUT_DIR / f"fusion_fold_{fold_idx}_predictions.csv"
    save_predictions_csv(val_ids, y_val, final_val_probs, "Dual-stream fusion", fold_idx, pred_path)

    pd.DataFrame(history).to_csv(OUT_DIR / f"fusion_fold_{fold_idx}_training_history.csv", index=False)

    # Save fold preprocessing metadata
    save_json({
        "res_pca_dim": RES_PCA_DIM,
        "topo_pca_dim": TOPO_PCA_DIM,
        "aux_pca_dim": AUX_PCA_DIM,
        "train_n": int(len(tr_idx)),
        "val_n": int(len(val_idx)),
        "note": "All scalers and PCA objects fit on training fold only."
    }, OUT_DIR / f"fusion_fold_{fold_idx}_preprocessing.json")

    fusion_results.append({
        "fold": int(fold_idx),
        "train_n": int(len(tr_idx)),
        "val_n": int(len(val_idx)),
        **final_val_metrics,
        "checkpoint_file": ckpt_path.name,
        "prediction_file": pred_path.name,
    })

    print(
        f"[Fusion] Fold {fold_idx} | "
        f"AUC={final_val_metrics['auc']:.4f} | "
        f"F1={final_val_metrics['f1']:.4f} | "
        f"ACC={final_val_metrics['acc']:.4f} | "
        f"BAL_ACC={final_val_metrics['balanced_acc']:.4f}"
    )

fusion_embeddings_test = test_emb_sum / max(test_count, 1)
attention_alpha_test = test_alpha_sum / max(test_count, 1)

# Save canonical fusion embeddings
np.save(OUT_DIR / "fusion_embeddings_train.npy", fusion_embeddings_train)
np.save(OUT_DIR / "fusion_embeddings_test.npy", fusion_embeddings_test)
np.save(OUT_DIR / "attention_weights_train.npy", attention_alpha_train)
np.save(OUT_DIR / "attention_weights_test.npy", attention_alpha_test)

pd.DataFrame({
