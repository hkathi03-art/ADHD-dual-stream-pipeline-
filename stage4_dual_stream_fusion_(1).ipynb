def evaluate_fusion_model(model, Xr, Xt, Xa, y_true, batch_size=32):
    model.eval()
    probs_list = []
    emb_list = []
    alpha_list = []

    with torch.no_grad():
        for start in range(0, len(Xr), batch_size):
            end = start + batch_size

            xr = torch.tensor(Xr[start:end], dtype=torch.float32, device=device)
            xt = torch.tensor(Xt[start:end], dtype=torch.float32, device=device)
            xa = torch.tensor(Xa[start:end], dtype=torch.float32, device=device)

            logits, alpha = model(xr, xt, xa, return_alpha=True)
            probs = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()

            emb, alpha_emb = model(xr, xt, xa, return_embedding=True, return_alpha=True)
            emb = emb.cpu().numpy()
            alpha_emb = alpha_emb.cpu().numpy()

            probs_list.append(probs)
            emb_list.append(emb)
            alpha_list.append(alpha_emb)

    prob_pos = np.concatenate(probs_list)
    embs = np.vstack(emb_list)
    alphas = np.vstack(alpha_list)
    metrics = compute_metrics_binary(y_true, prob_pos)
    return metrics, prob_pos, embs, alphas


