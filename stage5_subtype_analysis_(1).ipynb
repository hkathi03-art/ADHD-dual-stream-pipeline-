import os
import json
import random
import warnings
from pathlib import Path

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from tqdm.auto import tqdm

from sklearn.mixture import GaussianMixture
from sklearn.manifold import TSNE
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from scipy.stats import f_oneway, kruskal
from statsmodels.stats.multitest import multipletests
import networkx as nx
from google.colab import drive

warnings.filterwarnings("ignore")

# ------------------------------------------------------------
# Reproducibility
# ------------------------------------------------------------
SEED = 42
random.seed(SEED)
np.random.seed(SEED)
os.environ["PYTHONHASHSEED"] = str(SEED)

# ------------------------------------------------------------
# Paths
# ------------------------------------------------------------
drive.mount("/content/drive")

BASE_DIR = Path("/content/drive/MyDrive/ADHD_Pipeline")
PROC_DIR = BASE_DIR / "data" / "processed"
STAGE4_DIR = BASE_DIR / "stage4_outputs"
OUT_DIR = BASE_DIR / "stage5_outputs"
FIG_DIR = BASE_DIR / "figures"

OUT_DIR.mkdir(parents=True, exist_ok=True)
FIG_DIR.mkdir(parents=True, exist_ok=True)

# ------------------------------------------------------------
# Load canonical inputs
# ------------------------------------------------------------
print("Loading Stage 1 and Stage 4 canonical inputs...")

train_manifest = pd.read_csv(PROC_DIR / "train_subject_manifest.csv")
clinical_df = pd.read_csv(PROC_DIR / "clinical_metadata.csv")
fusion_train_df = pd.read_csv(STAGE4_DIR / "fusion_embeddings_train_with_ids.csv")

# Canonical subject IDs and labels
train_manifest["subject_id"] = train_manifest["subject_id"].astype(str)
clinical_df["subject_id"] = clinical_df["subject_id"].astype(str)
fusion_train_df["subject_id"] = fusion_train_df["subject_id"].astype(str)

assert fusion_train_df["subject_id"].is_unique, "Fusion embedding file contains duplicate subject IDs."
assert train_manifest["subject_id"].is_unique, "Train manifest contains duplicate subject IDs."

# Merge canonical train metadata + embeddings
train_df = (
    train_manifest[["subject_id", "ADHD_label", "subject_order_stage1"]]
    .merge(fusion_train_df, on="subject_id", how="inner")
    .merge(clinical_df, on="subject_id", how="left")
)

assert len(train_df) == len(train_manifest), "Stage 5 merge dropped training subjects unexpectedly."

train_df = train_df.sort_values("subject_order_stage1").reset_index(drop=True)

embed_cols = [c for c in train_df.columns if c.startswith("fusion_emb_")]
assert len(embed_cols) > 0, "No fusion embedding columns found."

X_fusion = train_df[embed_cols].to_numpy(dtype=np.float32)
y = train_df["ADHD_label"].astype(int).to_numpy()
subject_ids = train_df["subject_id"].astype(str).to_numpy()

print(f"Training rows        : {len(train_df)}")
print(f"Fusion embedding dim : {X_fusion.shape[1]}")
print(f"ADHD cases           : {(y == 1).sum()}")
print(f"Controls             : {(y == 0).sum()}")

# ------------------------------------------------------------
# Restrict subtype discovery to ADHD cases only
# ------------------------------------------------------------
adhd_mask = (y == 1)
adhd_df = train_df.loc[adhd_mask].copy().reset_index(drop=True)
adhd_subject_ids = adhd_df["subject_id"].astype(str).to_numpy()
X_adhd = adhd_df[embed_cols].to_numpy(dtype=np.float32)

print(f"ADHD-only subtype cohort: {len(adhd_df)} subjects")

# ------------------------------------------------------------
# Preprocess embeddings for clustering
# ------------------------------------------------------------
scaler = StandardScaler()
X_adhd_scaled = scaler.fit_transform(X_adhd)

# Optional PCA compression before clustering for stability
PCA_DIM = min(32, X_adhd_scaled.shape[1], len(X_adhd_scaled) - 1)
pca = PCA(n_components=max(2, PCA_DIM), random_state=SEED)
X_adhd_pca = pca.fit_transform(X_adhd_scaled)

print(f"PCA dimension used for clustering: {X_adhd_pca.shape[1]}")

# ------------------------------------------------------------
# GMM model selection by BIC
# ------------------------------------------------------------
k_values = [2, 3, 4, 5]
bic_rows = []

best_gmm = None
best_k = None
best_bic = np.inf

for k in k_values:
    gmm = GaussianMixture(
        n_components=k,
        covariance_type="full",
        random_state=SEED,
        n_init=10
    )
    gmm.fit(X_adhd_pca)
    bic = gmm.bic(X_adhd_pca)
    aic = gmm.aic(X_adhd_pca)

    bic_rows.append({
        "k": int(k),
        "bic": float(bic),
        "aic": float(aic)
    })

    if bic < best_bic:
        best_bic = bic
        best_k = k
        best_gmm = gmm

bic_df = pd.DataFrame(bic_rows)
bic_df.to_csv(OUT_DIR / "gmm_model_selection.csv", index=False)

# Plot BIC
fig, ax = plt.subplots(figsize=(7, 5))
ax.plot(bic_df["k"], bic_df["bic"], marker="o", label="BIC")
ax.plot(bic_df["k"], bic_df["aic"], marker="s", label="AIC")
ax.axvline(best_k, linestyle="--", alpha=0.7, label=f"Selected k={best_k}")
ax.set_xlabel("Number of clusters")
ax.set_ylabel("Criterion value")
ax.set_title("Stage 5 — GMM model selection")
ax.legend()
plt.tight_layout()
fig.savefig(FIG_DIR / "stage5_gmm_bic.png", dpi=150, bbox_inches="tight")
plt.show()

print(f"Selected subtype count by BIC: k = {best_k}")

# ------------------------------------------------------------
# Final subtype assignments
# ------------------------------------------------------------
subtype_labels = best_gmm.predict(X_adhd_pca)
subtype_probs = best_gmm.predict_proba(X_adhd_pca)

# Build canonical assignment table for ALL train subjects
# Controls get subtype = -1 and probability zeros
assign_df = train_df[["subject_id", "ADHD_label"]].copy()
assign_df["subtype"] = -1

for j in range(best_k):
    assign_df[f"prob_subtype_{j}"] = 0.0

adhd_idx_global = np.where(train_df["ADHD_label"].values == 1)[0]
assign_df.loc[adhd_idx_global, "subtype"] = subtype_labels

for j in range(best_k):
    assign_df.loc[adhd_idx_global, f"prob_subtype_{j}"] = subtype_probs[:, j]

assign_df.to_csv(OUT_DIR / "subtype_assignments.csv", index=False)

print("Saved subtype assignments to:", OUT_DIR / "subtype_assignments.csv")

# ------------------------------------------------------------
# t-SNE visualization (exploratory only)
# ------------------------------------------------------------
tsne = TSNE(
    n_components=2,
    perplexity=min(30, max(5, len(X_adhd_pca) // 5)),
    learning_rate="auto",
    init="pca",
    random_state=SEED
)
X_tsne = tsne.fit_transform(X_adhd_pca)

tsne_df = pd.DataFrame({
    "subject_id": adhd_subject_ids,
    "tsne_1": X_tsne[:, 0],
    "tsne_2": X_tsne[:, 1],
    "subtype": subtype_labels
})
tsne_df.to_csv(OUT_DIR / "subtype_tsne_coordinates.csv", index=False)

fig, ax = plt.subplots(figsize=(7, 6))
for subtype in sorted(np.unique(subtype_labels)):
    mask = subtype_labels == subtype
    ax.scatter(
        X_tsne[mask, 0],
        X_tsne[mask, 1],
        alpha=0.75,
        label=f"Subtype {subtype}"
    )
ax.set_title("Stage 5 — t-SNE of ADHD fusion embeddings")
ax.set_xlabel("t-SNE 1")
ax.set_ylabel("t-SNE 2")
ax.legend()
plt.tight_layout()
fig.savefig(FIG_DIR / "stage5_tsne.png", dpi=150, bbox_inches="tight")
plt.show()

# ------------------------------------------------------------
# Clinical subtype statistics
# Corrected:
# - exploratory, not confirmatory
# - uses only available numeric columns
# - FDR correction applied
# ------------------------------------------------------------
exclude_cols = set(["subject_id", "dataset_split", "ADHD_label", "subject_order_stage1", "subtype"])
exclude_cols.update(embed_cols)
exclude_cols.update([f"prob_subtype_{j}" for j in range(best_k)])

candidate_numeric_cols = [
    c for c in adhd_df.columns
    if c not in exclude_cols and pd.api.types.is_numeric_dtype(adhd_df[c])
]

stats_rows = []

adhd_df_stats = adhd_df.copy()
adhd_df_stats["subtype"] = subtype_labels

for col in candidate_numeric_cols:
    tmp = adhd_df_stats[["subtype", col]].dropna()
    if tmp.empty:
        continue

    groups = [grp[col].values for _, grp in tmp.groupby("subtype")]
    if len(groups) < 2:
        continue
    if any(len(g) < 3 for g in groups):
        # skip unstable tiny groups
        continue

    # Heuristic:
    # use ANOVA if all group sizes >= 20, else Kruskal
    try:
        if all(len(g) >= 20 for g in groups):
            stat, pval = f_oneway(*groups)
            test_name = "ANOVA"
        else:
            stat, pval = kruskal(*groups)
            test_name = "Kruskal-Wallis"
    except Exception:
        continue

    row = {
        "score": col,
        "test": test_name,
        "statistic": float(stat),
        "p_value": float(pval),
    }

    for subtype in range(best_k):
        vals = tmp.loc[tmp["subtype"] == subtype, col].values
        row[f"subtype_{subtype}_mean"] = float(np.mean(vals)) if len(vals) else np.nan
        row[f"subtype_{subtype}_sd"] = float(np.std(vals, ddof=1)) if len(vals) > 1 else np.nan

    stats_rows.append(row)

stats_df = pd.DataFrame(stats_rows)

if len(stats_df) > 0:
    reject, qvals, _, _ = multipletests(stats_df["p_value"].values, alpha=0.05, method="fdr_bh")
    stats_df["q_value_FDR"] = qvals
    stats_df["significant"] = reject
else:
    stats_df["q_value_FDR"] = []
    stats_df["significant"] = []

stats_df.to_csv(OUT_DIR / "clinical_subtype_stats.csv", index=False)

print("Saved clinical subtype stats to:", OUT_DIR / "clinical_subtype_stats.csv")

# ------------------------------------------------------------
# Clinical profile figure
# Show top variables by smallest q-value (exploratory)
# ------------------------------------------------------------
if len(stats_df) > 0:
    plot_vars = (
        stats_df.sort_values(["q_value_FDR", "p_value"], ascending=[True, True])
        .head(min(6, len(stats_df)))["score"]
        .tolist()
    )

    n_plots = len(plot_vars)
    ncols = 2
    nrows = int(np.ceil(n_plots / ncols))

    fig, axes = plt.subplots(nrows, ncols, figsize=(12, 4 * nrows))
    axes = np.array(axes).reshape(-1)

    for ax, col in zip(axes, plot_vars):
        tmp = adhd_df_stats[["subtype", col]].dropna()
        data = [tmp.loc[tmp["subtype"] == s, col].values for s in sorted(tmp["subtype"].unique())]
        ax.violinplot(data, positions=list(range(len(data))), showmedians=True)
        ax.set_title(col)
        ax.set_xlabel("Subtype")
        ax.set_ylabel("Value")
        ax.set_xticks(list(range(len(data))))
        ax.set_xticklabels([f"{s}" for s in sorted(tmp["subtype"].unique())])

    for ax in axes[n_plots:]:
        ax.axis("off")

    plt.tight_layout()
    fig.savefig(FIG_DIR / "stage5_clinical_profiles.png", dpi=150, bbox_inches="tight")
    plt.show()

# ------------------------------------------------------------
# Connectivity pattern analysis
# Corrected:
# - descriptive effect-size analysis only
# - uses Stage 1 FC magnitude
# - compares subtype vs controls
# ------------------------------------------------------------
FC_train_mag = np.load(PROC_DIR / "FC_train_magnitude.npy")

# Align FC arrays to canonical train order
assert len(FC_train_mag) == len(train_manifest), "FC magnitude length mismatch with train manifest."

fc_df = train_manifest[["subject_id", "ADHD_label", "subject_order_stage1"]].copy()
fc_df = fc_df.sort_values("subject_order_stage1").reset_index(drop=True)

# Build ID->FC row map
fc_id_to_idx = {sid: i for i, sid in enumerate(fc_df["subject_id"].astype(str).to_numpy())}

control_ids = fc_df.loc[fc_df["ADHD_label"] == 0, "subject_id"].astype(str).to_numpy()
control_idx = np.array([fc_id_to_idx[sid] for sid in control_ids], dtype=int)

def cohens_d(x, y):
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    nx = len(x)
    ny = len(y)
    if nx < 2 or ny < 2:
        return np.nan

    sx = np.var(x, ddof=1)
    sy = np.var(y, ddof=1)
    pooled = np.sqrt(((nx - 1) * sx + (ny - 1) * sy) / max(nx + ny - 2, 1))
    if pooled < 1e-12:
        return 0.0
    return (np.mean(x) - np.mean(y)) / pooled

iu = np.triu_indices(FC_train_mag.shape[1], k=1)

for subtype in range(best_k):
    subtype_ids = adhd_df_stats.loc[adhd_df_stats["subtype"] == subtype, "subject_id"].astype(str).to_numpy()
    subtype_idx = np.array([fc_id_to_idx[sid] for sid in subtype_ids], dtype=int)

    subtype_edges = FC_train_mag[subtype_idx][:, iu[0], iu[1]]
    control_edges = FC_train_mag[control_idx][:, iu[0], iu[1]]

    d_vals = np.array([
        cohens_d(subtype_edges[:, j], control_edges[:, j])
        for j in range(subtype_edges.shape[1])
    ], dtype=float)

    valid = np.isfinite(d_vals)
    d_valid = d_vals[valid]
    iu_u = iu[0][valid]
    iu_v = iu[1][valid]

    top_k = min(20, len(d_valid))
    top_idx = np.argsort(np.abs(d_valid))[::-1][:top_k]

    top_edges_df = pd.DataFrame({
        "node_i": iu_u[top_idx],
        "node_j": iu_v[top_idx],
        "cohens_d": d_valid[top_idx]
    }).sort_values("cohens_d", key=lambda s: np.abs(s), ascending=False)

    top_edges_df.to_csv(OUT_DIR / f"subtype_{subtype}_top_edges.csv", index=False)

# ------------------------------------------------------------
# Connectivity patterns figure
# Simple network view of strongest subtype-specific edges
# ------------------------------------------------------------
fig, axes = plt.subplots(1, best_k, figsize=(6 * best_k, 5))
if best_k == 1:
    axes = [axes]

for subtype, ax in enumerate(axes):
    path = OUT_DIR / f"subtype_{subtype}_top_edges.csv"
    top_edges_df = pd.read_csv(path)

    G = nx.Graph()
    for _, row in top_edges_df.head(15).iterrows():
        u = int(row["node_i"])
        v = int(row["node_j"])
        w = float(row["cohens_d"])
        G.add_edge(u, v, weight=abs(w), sign=np.sign(w))

    if len(G.nodes) == 0:
        ax.axis("off")
        continue

    pos = nx.spring_layout(G, seed=SEED)
    edge_colors = ["red" if G[u][v]["sign"] > 0 else "blue" for u, v in G.edges()]
    edge_widths = [1 + 2 * G[u][v]["weight"] / max(1e-8, max(nx.get_edge_attributes(G, "weight").values()))
                   for u, v in G.edges()]

    nx.draw_networkx_nodes(G, pos, node_size=120, ax=ax)
    nx.draw_networkx_edges(G, pos, edge_color=edge_colors, width=edge_widths, alpha=0.8, ax=ax)
    nx.draw_networkx_labels(G, pos, font_size=7, ax=ax)

    ax.set_title(f"Subtype {subtype} top connectivity patterns")
    ax.axis("off")

plt.tight_layout()
fig.savefig(FIG_DIR / "stage5_connectivity_patterns.png", dpi=150, bbox_inches="tight")
plt.show()

