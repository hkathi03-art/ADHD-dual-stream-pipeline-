    "embedding_dim": int(X_fusion.shape[1]),
    "clustering_method": "GaussianMixture",
    "selected_k": int(best_k),
    "selection_criterion": "BIC",
    "pca_dim_for_clustering": int(X_adhd_pca.shape[1]),
    "exploratory_note": (
        "Subtype discovery is exploratory and is performed only on ADHD cases using "
        "verified Stage 4 fusion embeddings with canonical subject IDs."
    ),
    "tsne_note": (
        "t-SNE is used for visualization only and should not be interpreted as evidence "
        "of subtype validity by itself."
    ),
    "clinical_stats_note": (
        "Clinical profile tests are exploratory and FDR-corrected. "
        "Absence of significant differences does not invalidate latent clustering."
    ),
    "connectivity_note": (
        "Top-edge outputs are descriptive effect-size rankings (Cohen's d), "
        "not family-wise-controlled inferential discoveries."
    ),
    "outputs": sorted([p.name for p in OUT_DIR.iterdir()])
}
save_json(stage5_registry, OUT_DIR / "stage5_registry.json")

# Save model selection rows as JSON too
save_json({"rows": bic_rows, "selected_k": int(best_k)}, OUT_DIR / "gmm_model_selection.json")

